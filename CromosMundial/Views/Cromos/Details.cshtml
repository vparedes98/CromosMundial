@model CromosMundial.Models.Cromo

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Cromo</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NumeroCromo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NumeroCromo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Edicion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Edicion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ValorMercado)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ValorMercado)
        </dd>
        <dt class = "col-sm-2">
            Jugador
        </dt>
        <dd class = "col-sm-10">
            @Model.Jugador?.Nombre
        </dd>
        <dt class = "col-sm-2">
            Álbum
        </dt>
        <dd class = "col-sm-10">
            @Model.Album?.Nombre
        </dd>
        <dt class = "col-sm-2">
            Foto
        </dt>
        <dd class = "col-sm-10">
            @if (!string.IsNullOrEmpty(Model.Foto))
            {
                <img src="@Model.Foto" width="150" />
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
