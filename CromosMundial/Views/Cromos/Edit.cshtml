@model CromosMundial.Models.Cromo

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Cromo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Foto" />
            <div class="form-group">
                <label asp-for="NumeroCromo" class="control-label"></label>
                <input asp-for="NumeroCromo" class="form-control" />
                <span asp-validation-for="NumeroCromo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Edicion" class="control-label"></label>
                <input asp-for="Edicion" class="form-control" />
                <span asp-validation-for="Edicion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ValorMercado" class="control-label"></label>
                <input asp-for="ValorMercado" class="form-control" />
                <span asp-validation-for="ValorMercado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FotoArchivo" class="control-label"></label>
                @if (!string.IsNullOrEmpty(Model.Foto))
                {
                    <div><img src="@Model.Foto" width="120" class="mb-2" /></div>
                }
                <input asp-for="FotoArchivo" type="file" class="form-control" />
                <span asp-validation-for="FotoArchivo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="JugadorId" class="control-label"></label>
                <select asp-for="JugadorId" class="form-control" asp-items="ViewBag.JugadorId"></select>
                <span asp-validation-for="JugadorId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AlbumId" class="control-label"></label>
                <select asp-for="AlbumId" class="form-control" asp-items="ViewBag.AlbumId"></select>
                <span asp-validation-for="AlbumId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
