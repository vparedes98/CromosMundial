@model CromosMundial.Models.Equipo

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Equipo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Logo" />
            <div class="form-group">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DirectorTecnico" class="control-label"></label>
                <input asp-for="DirectorTecnico" class="form-control" />
                <span asp-validation-for="DirectorTecnico" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AnioFundacion" class="control-label"></label>
                <input asp-for="AnioFundacion" class="form-control" />
                <span asp-validation-for="AnioFundacion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LogoArchivo" class="control-label"></label>
                @if (!string.IsNullOrEmpty(Model.Logo))
                {
                    <div><img src="@Model.Logo" width="120" class="mb-2" /></div>
                }
                <input asp-for="LogoArchivo" type="file" class="form-control" />
                <span asp-validation-for="LogoArchivo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GrupoMundialista" class="control-label"></label>
                <input asp-for="GrupoMundialista" class="form-control" />
                <span asp-validation-for="GrupoMundialista" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PaisId" class="control-label"></label>
                <select asp-for="PaisId" class="form-control" asp-items="ViewBag.PaisId"></select>
                <span asp-validation-for="PaisId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
